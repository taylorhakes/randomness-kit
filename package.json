{
  "name": "randomness-kit",
  "version": "0.1.0",
  "description": "Small, dependency-free, secure-by-default randomness utilities (bytes, integers, strings) for Node, browsers, Deno, and Bun.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "random",
    "randomness",
    "csprng",
    "crypto",
    "random-bytes",
    "random-int",
    "random-string",
    "secure"
  ],
  "license": "MIT",
  "author": "Taylor Hakes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taylorhakes/randomness-kit.git"
  },
  "bugs": {
    "url": "https://github.com/taylorhakes/randomness-kit/issues"
  },
  "homepage": "https://github.com/taylorhakes/randomness-kit#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  }
}
